generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/hangman_game/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Game {
  id              String   @id
  status          String   @default("Lobby")
  word            String   @default("")
  maskedWord      String   @default("")
  hint1           String   @default("")
  hint2           String   @default("")
  hint3           String   @default("")
  score           Float    @default(100)
  penaltyConsonant Float?  
  penaltyVowel    Float?   
  penaltyHint     Float    @default(15)
  guessedLetters  String   @default("")
  incorrectGuesses String  @default("")
  revealedHints   Int      @default(0)
  hostName        String   @default("")
  guesserName     String   @default("")
  hostConnected   Boolean  @default(false)
  guesserConnected Boolean @default(false)
  winner          String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
